{
  "tests": [
    {
      "name": "Missing order_number",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "order_number required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Not found order",
      "method": "GET",
      "path": "/?order_number=ORD-00000000-000000",
      "expectedStatus": 404,
      "expectedBody": {"error": "Order not found"},
      "bodyMatcher": "partial"
    }
  ]
}
